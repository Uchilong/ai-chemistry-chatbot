# AI Chemistry Chatbot Environment Variables
# Copy this file to .env and fill in your API keys

# === REQUIRED FOR BASIC FUNCTIONALITY ===
# Gemini API Key (for image analysis and main AI responses)
GEMINI_API_KEY=your_gemini_api_key_here

# === OPTIONAL BUT RECOMMENDED ===
# Mistral API Key (for fast text-only responses)
MISTRAL_API_KEY=your_mistral_api_key_here

# Groq API Key (for ultra-fast responses)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Wolfram Alpha App ID (for equation balancing and calculations)
# Get from: https://developer.wolframalpha.com/
WOLFRAM_APP_ID=your_wolfram_app_id_here

# Pollinations API Key (for image generation - optional, has free tier)
POLLINATIONS_API_KEY=your_pollinations_api_key_here

# === BACKEND CONFIGURATION ===
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG_MODE=false

# === UI SETTINGS ===
UI_THEME_MODE=auto
DEFAULT_CHEMISTRY_LEVEL=highschool
DEFAULT_RESPONSE_STYLE=balanced
